# Copiar como .env y completar los valores

# Base de datos (SQLite para dev, PostgreSQL para prod)
DATABASE_URL=sqlite:///./smartreceipt.db
# DATABASE_URL=postgresql://user:password@localhost/smartreceipt

# Clover
CLOVER_APP_ID=your_clover_app_id
CLOVER_APP_SECRET=your_clover_app_secret
CLOVER_API_BASE_URL=https://apisandbox.dev.clover.com  # sandbox para dev

# IA (opcional — para enriquecer insights con LLM)
OPENAI_API_KEY=

# App
SECRET_KEY=cambia-esto-en-produccion
DEBUG=true
